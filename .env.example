# Flask Secret Key (required for session management)
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Deployment Configuration
# CRITICAL: GUNICORN_WORKERS must remain 1 for SQLite + embedded workers
# DO NOT set GUNICORN_WORKERS environment variable - it is enforced in gunicorn.docker.conf.py
# GUNICORN_THREADS can be increased for better I/O-bound performance (default: 4)
GUNICORN_THREADS=4

# Set to false to hide library UI (download-only mode)
ENABLE_LIBRARY=true

# Configure notification services based on Apprise: https://github.com/caronc/apprise#supported-notifications
# Examples:
# - Telegram: tgram://BOT_TOKEN/CHAT_ID
# - Discord: discord://webhook_id/webhook_token
# - Slack: slack://tokenA/tokenB/tokenC
# - Email: mailto://user:pass@gmail.com
# - Pushover: pover://user_key/app_token
NOTIFICATION_URLS=

# Copy EPUBs to an external directory for integration with other apps (e.g., Calibre-Web)
# Example: /path/to/calibre-web/auto-import
EXTERNAL_EPUB_PATH=

# Auto-update: Check for new chapters in multi-part stories
# DISABLED by default to avoid overloading Literotica's servers
# 
# LitKeeper auto-generates a unique random weekly schedule on first startup
# (saved in database) to prevent coordinated load across users.
# View the generated schedule in Settings UI and enable the feature there.
#
# When enabled, LitKeeper will:
# - Check stories with auto_update_enabled=true for new chapters
# - Add 0-60 minute random jitter to start time (prevents coordinated load)
# - Wait 30-60 seconds between each story check (rate limiting)
# - Automatically download new chapters and regenerate EPUBs
#
# AUTO_UPDATE_SCHEDULE=
